generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  role       Role
  entityId   String
  isApproved Boolean  @default(true)
  isActive   Boolean  @default(true)
  lastLogin  DateTime?
  createdAt  DateTime @default(now())
}

enum Role {
  RESTAURANT
  DRIVER
  SHELTER
  ADMIN
}
model Donor {
  id            String        @id @default(uuid())
  name          String
  address       String
  lat           Float
  lng           Float
  contactName   String
  contactPhone  String
  email         String        @unique
  password      String
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  foodPostings  FoodPosting[]
}

model Driver {
  id              String      @id @default(uuid())
  name            String
  email           String      @unique
  password        String
  phone           String
  vehicleType     VehicleType
  capacityKg      Float
  currentLat      Float?
  currentLng      Float?
  isAvailable     Boolean     @default(false)
  trustScore      Float       @default(80.0)
  totalDeliveries Int         @default(0)
  totalKgRescued  Float       @default(0)
  createdAt       DateTime    @default(now())
  pickups         Pickup[]
  level         String   @default("ROOKIE")
streakDays    Int      @default(0)
}

model Shelter {
  id                  String    @id @default(uuid())
  name                String
  address             String
  lat                 Float
  lng                 Float
  contactName         String
  contactPhone        String
  email               String    @unique
  password            String
  maxCapacityKg       Float
  currentCommittedKg  Float     @default(0)
  acceptingFrom       String
  acceptingTill       String
  isAccepting         Boolean   @default(true)
  needsVeg            Boolean   @default(true)
  needsNonVeg         Boolean   @default(true)
  priorityNote        String?
  createdAt           DateTime  @default(now())
  pickups             Pickup[]
}

model FoodPosting {
  id            String        @id @default(uuid())
  donorId       String
  foodType      FoodType
  isVeg         Boolean
  quantityKg    Float
  description   String?
  closingTime   DateTime
  urgencyScore  Float         @default(0)
  status        PostingStatus @default(AVAILABLE)
  createdAt     DateTime      @default(now())
  donor         Donor         @relation(fields: [donorId], references: [id])
  pickup        Pickup?
  safetyScore     Float    @default(100)
isRefrigerated  Boolean  @default(false)
timeSinceCooked Int      @default(0)
}

model Pickup {
  id            String       @id @default(uuid())
  foodPostingId String       @unique
  driverId      String?
  shelterId     String?
  status        PickupStatus @default(PENDING)
  version       Int          @default(0)
  routeData     Json?
  claimedAt     DateTime?
  pickedUpAt    DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime     @default(now())
  foodPosting   FoodPosting  @relation(fields: [foodPostingId], references: [id])
  driver        Driver?      @relation(fields: [driverId], references: [id])
  shelter       Shelter?     @relation(fields: [shelterId], references: [id])
}

model Badge {
  id          String   @id @default(uuid())
  entityId    String
  entityType  String
  badgeType   String
  badgeName   String
  description String
  earnedAt    DateTime @default(now())
}

model Streak {
  id            String   @id @default(uuid())
  entityId      String   @unique
  entityType    String
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActiveAt  DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum VehicleType {
  BIKE
  CAR
  VAN
  TRUCK
}

enum FoodType {
  HOT_MEAL
  BAKERY
  SEALED
  RAW_PRODUCE
  BEVERAGES
}

enum PostingStatus {
  AVAILABLE
  MATCHED
  PICKED_UP
  DELIVERED
  EXPIRED
}

enum PickupStatus {
  PENDING
  CLAIMED
  IN_PROGRESS
  DELIVERED
  FAILED
}